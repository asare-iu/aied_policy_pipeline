# ----------------------------
# EXCEPTIONS: files we DO want tracked
# (negation rules must come after the ignore)
# ----------------------------

# Keep small manifests and inventories
!data/manifests/
!data/manifests/**

!data/derived/step0_document_inventory.csv
!data/derived/step0_document_inventory_deduped.csv

# Keep config + lexicons + methods/docs
!config/
!config/**
!resources/
!resources/**
!methods/
!methods/**
!docs/
!docs/**
!scripts/
!scripts/**
!src/
!src/**
!figures/
!figures/**

# Keep specific “small metadata” anywhere (even if under ignored dirs)
!**/*_runtime_params.json
!**/models_metadata.json
!**/explained_variance.csv
!**/top_terms.csv
!**/top_terms_long.csv
!**/pc_interpretations_deep.csv
!**/row_alignment.csv
!**/pca_full_metadata.json
!**/pca_pc_labels_template.csv
!**/pca_pc_labels_filled.csv
!**/pca_pc_exemplars.jsonl

# --- big/binary artifacts: never commit ---
*.joblib
*.npz
*.parquet
*.jsonl
*.tar.gz

# ignore python cache
__pycache__/
scripts/__pycache__/

