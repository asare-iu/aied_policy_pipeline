{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "baseline_statement_type",
    "final_statement_type",
    "recoverable_from_other",
    "other_reason_bucket",
    "confidence",
    "evidence_span",
    "missing_elements",
    "notes_for_humans",
    "recommended_pipeline_change"
  ],
  "properties": {
    "chunk_id": { "type": "string" },
    "baseline_statement_type": { "type": "string", "enum": ["other","norm","strategy","rule","principle"] },
    "final_statement_type": { "type": "string", "enum": ["other","norm","strategy","rule","principle"] },
    "recoverable_from_other": { "type": "string", "enum": ["Y","N"] },
    "other_reason_bucket": {
      "anyOf": [
        { "type": "null" },
        { "type": "string",
          "enum": [
            "definition_glossary",
            "problem_framing_diagnosis",
            "scope_applicability_exemption",
            "actor_role_description",
            "implementation_process_timeline",
            "monitoring_reporting_evaluation",
            "resource_funding_capacity",
            "aspirational_vision_rhetoric",
            "context_dependent_missing_deontic_or_aim",
            "non_institutional_background"
          ]
        }
      ]
    },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "evidence_span": { "type": "string" },
    "missing_elements": { "type": "array", "items": { "type": "string" } },
    "notes_for_humans": { "type": "string" },
    "recommended_pipeline_change": { "type": "array", "items": { "type": "string" } }
  }
}
